+            lines.append(f'  Review bundle: python3 tools/infra_tmp_cleanup.py {args}')
+            lines.append(f'  Apply bundle: python3 tools/infra_tmp_cleanup.py --apply {args}')
+            continue
+
+        shortfall = max(0, required_bytes - total_reclaim)
