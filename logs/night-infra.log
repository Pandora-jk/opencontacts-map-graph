+            lines.append(f'  Apply bundle: python3 tools/infra_home_cache_cleanup.py --apply {apply_args}')
+            continue
+
+        shortfall = max(0, required_bytes - total_reclaim)
+        apply_args = suggested_home_cache_apply_args(candidates)
+        lines.append(
