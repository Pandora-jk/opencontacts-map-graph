+            continue
+
+        bundle = select_candidate_bundle(candidates, required_bytes=required_bytes)
+        bundle_reclaim = total_candidate_bytes(bundle)
+        lines.append(f'- Need about {human_size(required_bytes)} reclaimed to reach <={target_pct}% on /')
