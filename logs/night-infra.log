+                "--nsswitch-path",
+                str(nsswitch),
+            ]
+
+            with mock.patch.object(sys, "argv", argv), mock.patch.object(
+                infra_mdns_hardening, "current_port_lines", return_value="udp 0.0.0.0:5353"
+            ), mock.patch.object(
+                infra_mdns_hardening,
+                "run_cmd",
+                return_value="UNCONN 0 0 0.0.0.0:5353 0.0.0.0:*",
