+            output = stdout.getvalue()
+            self.assertIn(f"INSTALLED_DROPIN {live}", output)
+            self.assertIn(f"live drop-in installed: {live} (mode 0644)", output)
+            self.assertIn("LIVE_VALIDATION_DONE", output)
+
+
+if __name__ == "__main__":
