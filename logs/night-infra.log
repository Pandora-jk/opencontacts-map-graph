+def select_candidate_bundle(candidates: list[object], *, required_bytes: int) -> list[object]:
+    if required_bytes <= 0:
+        return []
+
+    selected: list[object] = []
+    reclaimed = 0
+    for candidate in sorted(candidates, key=lambda item: getattr(item, 'size_bytes', 0), reverse=True):
