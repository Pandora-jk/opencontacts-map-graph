+    except (OSError, RuntimeError, subprocess.TimeoutExpired):
+        return []
+
+    if not candidates:
+        return []
+
+    total_reclaim = total_candidate_bytes(candidates)
+    targets: list[int] = []
+    if used_pct > DISK_CRITICAL_THRESHOLD:
