+            root = Path(temp_dir)
+            stage_dir = root / "stage"
+            nsswitch = root / "nsswitch.conf"
+            resolved_conf = root / "resolved.conf"
+            nsswitch.write_text("hosts: files dns\n", encoding="utf-8")
+            resolved_conf.write_text("", encoding="utf-8")
+
+            stdout = io.StringIO()
+            argv = [
+                "infra_mdns_hardening.py",
+                "--stage-dir",
