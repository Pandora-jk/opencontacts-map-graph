+        summary["total"] += 1
+        if conclusion in GITHUB_FAILURE_CONCLUSIONS or state in {"ERROR", "FAILURE"}:
+            summary["failing"].append(name)
+        elif status in GITHUB_PENDING_STATES or state in GITHUB_PENDING_STATES:
+            summary["pending"].append(name)
+        elif conclusion in GITHUB_SUCCESS_CONCLUSIONS or state == "SUCCESS":
+            summary["successful"].append(name)
+
+    if summary["failing"]:
+        summary["state"] = "failure"
+    elif summary["pending"]:
+        summary["state"] = "pending"
+    elif summary["successful"]:
+        summary["state"] = "success"
