+def origin_remote_url(repo: Path) -> str:
+    result = run_git(repo, "remote", "get-url", "origin", check=False)
+    return result.stdout.strip()
+
+
+def github_repo_slug(remote_url: str) -> str:
+    patterns = (
+        r"^https://github\.com/(?P<slug>[^/]+/[^/]+?)(?:\.git)?/?$",
+        r"^git@github\.com:(?P<slug>[^/]+/[^/]+?)(?:\.git)?$",
+        r"^ssh://git@github\.com/(?P<slug>[^/]+/[^/]+?)(?:\.git)?/?$",
+    )
+    for pattern in patterns:
+        match = re.match(pattern, remote_url.strip())
+        if match:
+            return match.group("slug")
+    return ""
+
+
+def github_checks_summary(rollup: object) -> dict[str, object]:
+    summary = {
+        "state": "missing",
+        "total": 0,
+        "successful": [],
+        "pending": [],
+        "failing": [],
+    }
+    if not isinstance(rollup, list) or not rollup:
+        return summary
+
+    for raw in rollup:
+        if not isinstance(raw, dict):
+            continue
+        name = str(
+            raw.get("name")
+            or raw.get("context")
+            or raw.get("workflowName")
+            or raw.get("__typename")
+            or "check"
+        )
+        conclusion = str(raw.get("conclusion") or "").upper()
+        status = str(raw.get("status") or "").upper()
+        state = str(raw.get("state") or "").upper()
+        summary["total"] += 1
+        if conclusion in GITHUB_FAILURE_CONCLUSIONS or state in {"ERROR", "FAILURE"}:
+            summary["failing"].append(name)
+        elif status in GITHUB_PENDING_STATES or state in GITHUB_PENDING_STATES:
+            summary["pending"].append(name)
+        elif conclusion in GITHUB_SUCCESS_CONCLUSIONS or state == "SUCCESS":
+            summary["successful"].append(name)
+
+    if summary["failing"]:
+        summary["state"] = "failure"
+    elif summary["pending"]:
+        summary["state"] = "pending"
+    elif summary["successful"]:
+        summary["state"] = "success"
+    return summary
+
+
+def parse_github_pr_payload(payload: str) -> dict[str, object] | None:
+    try:
+        raw = json.loads(payload)
+    except json.JSONDecodeError:
+        return None
+    if isinstance(raw, list):
+        if not raw:
+            return None
+        raw = raw[0]
+    if not isinstance(raw, dict):
+        return None
+
+    checks = github_checks_summary(raw.get("statusCheckRollup"))
+    return {
+        "number": raw.get("number"),
+        "url": str(raw.get("url") or ""),
+        "state": str(raw.get("state") or ""),
+        "title": str(raw.get("title") or ""),
+        "head_ref": str(raw.get("headRefName") or ""),
+        "base_ref": str(raw.get("baseRefName") or ""),
+        "checks": checks,
+    }
+
+
+def load_github_pr_metadata(repo: Path, branch: str) -> dict[str, object]:
+    remote_url = origin_remote_url(repo)
+    slug = github_repo_slug(remote_url)
+    if not slug:
+        return {"available": False, "repo": "", "reason": "origin is not a GitHub remote", "pr": None}
+    if not shutil.which("gh"):
+        return {"available": False, "repo": slug, "reason": "gh CLI not installed", "pr": None}
+
+    result = subprocess.run(
+        [
+            "gh",
+            "pr",
+            "list",
+            "--repo",
+            slug,
+            "--head",
+            branch,
+            "--state",
+            "open",
+            "--json",
+            "number,url,state,title,headRefName,baseRefName,statusCheckRollup",
+        ],
+        capture_output=True,
+        text=True,
+        encoding="utf-8",
+        errors="replace",
+    )
+    if result.returncode != 0:
+        reason = result.stderr.strip() or result.stdout.strip() or "gh pr list failed"
+        return {"available": False, "repo": slug, "reason": reason, "pr": None}
+
+    pr = parse_github_pr_payload(result.stdout)
+    if not pr:
+        return {"available": True, "repo": slug, "reason": "no open PR found", "pr": None}
+    return {"available": True, "repo": slug, "reason": "", "pr": pr}
+
+
