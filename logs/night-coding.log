+            template = root / "template.md"
+            outline = root / "outline.md"
+
+            template.write_text(
+                "# Template\n\n"
+                "## Working Title\n"
+                "## Pricing and Packaging\n",
+                encoding="utf-8",
+            )
+            outline.write_text(
