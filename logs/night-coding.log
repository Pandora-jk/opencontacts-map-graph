+        "is_draft": bool(payload.get("isDraft", False)),
+        "review_decision": review_decision or "missing",
+        "checks_state": checks_state,
+        "checks_summary": checks_summary,
+        "source": "snapshot",
+    }
+
+
+def load_github_snapshot_index(github_dir: Path) -> dict[str, dict[str, object]]:
+    index: dict[str, dict[str, object]] = {}
+    if not github_dir.exists():
+        return index
+
+    for path in sorted(github_dir.glob("*.json")):
