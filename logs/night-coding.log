+            "gh",
+            "pr",
+            "view",
+            branch,
+            "--json",
+            "number,url,state,isDraft,reviewDecision,headRefName,statusCheckRollup",
+        ],
+        cwd=repo,
+        capture_output=True,
+        text=True,
+        encoding="utf-8",
+        errors="replace",
+    )
+    if result.returncode != 0:
+        return None
+    try:
+        payload = json.loads(result.stdout)
+    except json.JSONDecodeError:
+        return None
+    normalized = normalize_github_pr(payload, branch)
+    if normalized:
+        normalized["source"] = "gh"
+    return normalized
+
+
