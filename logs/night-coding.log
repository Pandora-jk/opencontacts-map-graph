+
+def normalize_github_state(value: object) -> str:
+    if value is None:
+        return ""
+    return str(value).strip().lower().replace("-", "_")
+
+
+def classify_check_rollup(entries: object) -> tuple[str, list[str]]:
+    if not isinstance(entries, list) or not entries:
+        return "missing", []
+
+    observed: list[tuple[str, str]] = []
+    for entry in entries:
+        if not isinstance(entry, dict):
+            continue
+        typename = str(entry.get("__typename", "")).strip()
+        label = str(entry.get("name") or entry.get("context") or typename or "check").strip()
+        status = normalize_github_state(entry.get("status"))
+        conclusion = normalize_github_state(entry.get("conclusion"))
+        state = normalize_github_state(entry.get("state"))
+
+        if typename == "CheckRun":
+            if status and status != "completed":
+                observed.append(("pending", f"{label}:{status}"))
+                continue
+            if conclusion in SUCCESS_CONCLUSIONS:
+                observed.append(("green", f"{label}:{conclusion}"))
+                continue
+            if conclusion in FAILURE_CONCLUSIONS:
+                observed.append(("red", f"{label}:{conclusion}"))
+                continue
+            if conclusion:
+                observed.append(("pending", f"{label}:{conclusion}"))
+                continue
+            observed.append(("pending", f"{label}:pending"))
+            continue
+
+        if typename == "StatusContext":
+            if state in SUCCESS_STATES:
+                observed.append(("green", f"{label}:{state}"))
+            elif state in FAILURE_STATES:
+                observed.append(("red", f"{label}:{state}"))
+            elif state:
+                observed.append(("pending", f"{label}:{state}"))
+            else:
+                observed.append(("pending", f"{label}:pending"))
+            continue
+
+        if state in SUCCESS_STATES or conclusion in SUCCESS_CONCLUSIONS:
+            observed.append(("green", f"{label}:{state or conclusion}"))
+        elif state in FAILURE_STATES or conclusion in FAILURE_CONCLUSIONS:
+            observed.append(("red", f"{label}:{state or conclusion}"))
+        elif status in PENDING_STATES or state in PENDING_STATES or conclusion:
+            observed.append(("pending", f"{label}:{status or state or conclusion}"))
+
+    if not observed:
+        return "missing", []
+    states = {item[0] for item in observed}
+    if "red" in states:
+        return "red", [item[1] for item in observed]
+    if "pending" in states:
+        return "pending", [item[1] for item in observed]
+    return "green", [item[1] for item in observed]
+
+
+def normalize_github_pr(payload: dict[str, object], branch: str) -> dict[str, object] | None:
+    head_ref = str(payload.get("headRefName") or payload.get("branch") or "").strip()
+    if head_ref and head_ref != branch:
+        return None
+
+    checks_state, checks_summary = classify_check_rollup(payload.get("statusCheckRollup"))
+    review_decision = normalize_github_state(payload.get("reviewDecision"))
+    pr_state = normalize_github_state(payload.get("state"))
+
+    return {
+        "number": payload.get("number"),
+        "url": str(payload.get("url", "")).strip(),
+        "branch": head_ref or branch,
+        "state": pr_state or "missing",
+        "is_draft": bool(payload.get("isDraft", False)),
+        "review_decision": review_decision or "missing",
+        "checks_state": checks_state,
+        "checks_summary": checks_summary,
+        "source": "snapshot",
+    }
+
+
+def load_github_snapshot_index(github_dir: Path) -> dict[str, dict[str, object]]:
+    index: dict[str, dict[str, object]] = {}
+    if not github_dir.exists():
+        return index
+
+    for path in sorted(github_dir.glob("*.json")):
+        try:
+            payload = json.loads(path.read_text(encoding="utf-8"))
+        except json.JSONDecodeError:
+            continue
+
+        candidates = payload if isinstance(payload, list) else [payload]
+        for candidate in candidates:
+            if not isinstance(candidate, dict):
+                continue
+            branch = str(candidate.get("branch") or candidate.get("headRefName") or "").strip()
+            pr_payload = candidate.get("pr") if isinstance(candidate.get("pr"), dict) else candidate
+            if not isinstance(pr_payload, dict):
+                continue
+            branch = branch or str(pr_payload.get("headRefName") or pr_payload.get("branch") or "").strip()
+            if not branch:
+                continue
+            normalized = normalize_github_pr(pr_payload, branch)
+            if normalized:
+                index[branch] = normalized
+    return index
+
+
+def fetch_github_pr(repo: Path, branch: str) -> dict[str, object] | None:
+    if not gh_available() or not repo_uses_github(repo):
+        return None
+    result = subprocess.run(
+        [
+            "gh",
+            "pr",
+            "view",
+            branch,
+            "--json",
+            "number,url,state,isDraft,reviewDecision,headRefName,statusCheckRollup",
+        ],
+        cwd=repo,
+        capture_output=True,
+        text=True,
+        encoding="utf-8",
+        errors="replace",
+    )
+    if result.returncode != 0:
+        return None
+    try:
+        payload = json.loads(result.stdout)
+    except json.JSONDecodeError:
+        return None
+    normalized = normalize_github_pr(payload, branch)
+    if normalized:
+        normalized["source"] = "gh"
+    return normalized
+
+
+def github_pr_for_branch(
+    repo: Path,
+    branch: str,
+    github_index: dict[str, dict[str, object]] | None,
+) -> dict[str, object] | None:
+    if github_index and branch in github_index:
+        return dict(github_index[branch])
+    return fetch_github_pr(repo, branch)
+
