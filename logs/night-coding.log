+                observed.append(("green", f"{label}:{state}"))
+            elif state in FAILURE_STATES:
+                observed.append(("red", f"{label}:{state}"))
+            elif state:
+                observed.append(("pending", f"{label}:{state}"))
+            else:
+                observed.append(("pending", f"{label}:pending"))
+            continue
+
+        if state in SUCCESS_STATES or conclusion in SUCCESS_CONCLUSIONS:
+            observed.append(("green", f"{label}:{state or conclusion}"))
+        elif state in FAILURE_STATES or conclusion in FAILURE_CONCLUSIONS:
+            observed.append(("red", f"{label}:{state or conclusion}"))
+        elif status in PENDING_STATES or state in PENDING_STATES or conclusion:
+            observed.append(("pending", f"{label}:{status or state or conclusion}"))
+
+    if not observed:
+        return "missing", []
+    states = {item[0] for item in observed}
+    if "red" in states:
+        return "red", [item[1] for item in observed]
+    if "pending" in states:
+        return "pending", [item[1] for item in observed]
+    return "green", [item[1] for item in observed]
